HOSTNAME=nagadmin

# Username/password for accessing the Nagios UI.
# Not to be confused with the credentials used for accessing Nagadmin.
# If you're changing this in the future, you'd need to delete `etc/services/nagios/etc/htpasswd.users`
# to make the new values take effect.
NAGIOSADMIN_USER=nagiosadmin
NAGIOSADMIN_PASS=nagios

# The timezone that Nagios would use
TZ=Europe/Sofia

NGINX_HTTP_BIND_ADDRESS=127.0.0.1:20180
NAGIOS_HTTP_BIND_ADDRESS=127.0.0.1:20188

# Outgoing mail relay (production only; used by the `mailer` service in
# compose.prod.yml). The development environment captures mail with mailcrab
# instead and ignores these.
#
# Leave SMARTHOST empty to deliver directly to recipients' MX servers. Set it to
# relay through an authenticated SMTP provider (recommended) — the on-disk spool
# then tolerates provider downtime and retries until delivery succeeds.
#
# SMARTHOST format: host::port (e.g. smtp.example.com::587).
# SMARTHOST_PROTOCOL: smtp (STARTTLS, port 587) or smtps (implicit TLS, port 465).
SMARTHOST=
SMARTHOST_PROTOCOL=smtp
SMTP_USERNAME=
SMTP_PASSWORD=
