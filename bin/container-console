#!/bin/bash

# This captures arguments, preserving quotes, so they can be forwarded to another shell.
# See: https://stackoverflow.com/a/8723305
C=''
for i in "$@"; do
    i="${i//\\/\\\\}"
    C="$C \"${i//\"/\\\"}\""
done

docker_compose_run_flags='-T'
if [ -t 0 ] && [ -t 1 ]; then
	# Fully interactive (both stdin and stdout are a TTY): allocate a TTY so
	# prompts work. When stdin is piped (e.g. `echo body | ... send-notification:email`)
	# we must keep -T, otherwise Docker's pseudo-TTY swallows the piped input.
	docker_compose_run_flags=''
fi

docker compose -f compose.yml -p devture-nagadmin \
run $docker_compose_run_flags --rm --user='100:101' php sh -c \
"cd /code/app && NAGADMIN_RUNTIME_DIR=/tmp/nagadmin-console php bin/console $C"
