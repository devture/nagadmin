{% import '@DevtureNagios/macros.html.twig' as macros %}

{% if items|length == 0 %}
	No items found.
{% else %}
	<table class="table table-bordered table-striped table-condensed">
		<thead>
			<tr>
				<th>Date</th>
				<th class="d-none d-sm-table-cell">Type</th>
				<th>Value</th>
			</tr>
		</thead>
		<tbody>
		{% for entity in items %}
			<tr>
				<td nowrap="nowrap">
					{{ macros.relative_time(entity.timestamp) }} ago
				</td>
				<td class="d-none d-sm-table-cell">
					{{ entity.type }}
				</td>
				<td>
					<span class="d-inline d-sm-none"><strong>{{ entity.type }}</strong>:</span>
					<span style="word-break: break-all">
						{{ entity.value }}
					</span>

					{% set info_link = none %}

					{% if entity.service is not none %}
						{% set info_link = path('devture_nagios.service.view', {'id': entity.service.id}) %}
					{% else %}
						{% if entity.host is not none %}
							{% set info_link = path('devture_nagios.host.view', {'id': entity.host.id}) %}
						{% endif %}
					{% endif %}

					{% if info_link is not none %}
						<a class="btn btn-secondary btn-sm float-end" href="{{ info_link }}">
						{% if entity.host %}
							<img src="//www.google.com/s2/favicons?domain={{ entity.host.address }}" alt="" />
						{% else %}
							<i class="fa-solid fa-circle-info"></i>
						{% endif %}
						</a>
					{% endif %}
				</td>
			</tr>
		{% endfor %}
		</tbody>
	</table>
{% endif %}
