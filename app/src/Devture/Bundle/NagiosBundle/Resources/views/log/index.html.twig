{% extends '@DevtureNagios/nagios_layout.html.twig' %}

{% block title %}Logs / {{ parent() }}{% endblock %}

{% block devture_nagios_content %}
	{% set reactProps = {
		'urls': {
			'logsList': path('devture_nagios.api.log.list'),
			'logsListIfNewerThan': path('devture_nagios.api.log.list', {'ifNewerThanId': '__LAST_SEEN_ID__'}),
			'hostView': path('devture_nagios.host.view', {'id': '__ID__'}),
			'serviceView': path('devture_nagios.service.view', {'id': '__ID__'}),
		},
	} %}
	{{ reactjs_render_component('LogsApp', reactProps) }}
{% endblock %}
