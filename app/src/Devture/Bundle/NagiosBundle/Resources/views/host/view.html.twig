{% extends '@DevtureNagios/nagios_layout.html.twig' %}

{% block title %}Host: {{ entity.name }} / {{ parent() }}{% endblock %}

{% block devture_nagios_content %}
	{% if is_granted('ROLE_CONFIGURATION_MANAGEMENT') %}
		{% include '@DevtureNagios/host/toolbar.html.twig' with {'entity': entity, 'currentSection': 'status'} only %}
	{% endif %}

	<div>
		<fieldset>
			<div class="row mb-3">
				<label class="col-lg-2 col-form-label"><i class="fa-solid fa-table-cells-large"></i> Host</label>
				<div class="col-lg-10 clearfix">
					<img src="//www.google.com/s2/favicons?domain={{ entity.address }}" alt="" />
					{{ entity.name }}
					({{ entity.address }})
				</div>
			</div>

			<div class="row mb-3">
				<label class="col-lg-2 col-form-label">Groups</label>
				<div class="col-lg-10">
				{% for group in entity.groups %}
					<span class="badge label-nagadmin"
						style="background-color: {{ group|devture_nagios_colorize }};">{{ group }}</span>
				{% endfor %}
				</div>
			</div>

			<div class="row mb-3">
				<label class="col-lg-2 col-form-label"><i class="fa-solid fa-signal"></i> Services</label>
				<div class="col-lg-10">
					{% set reactProps = {
						'hostId': '' ~ entity.id,
						'urls': {
							'hostInfo': path('devture_nagios.api.host.info', {'id': '__ID__'}),
							'recheckServices': path('devture_nagios.api.host.recheck_services', {'id': '__ID__', 'recheckType': '__RECHECK_TYPE__', 'token': csrf_token('nagadmin')}),
							'commandsList': path('devture_nagios.api.command.list', {'type': 'serviceCheck'}),
							'hostView': path('devture_nagios.host.view', {'id': '__ID__'}),
							'serviceView': path('devture_nagios.service.view', {'id': '__ID__'}),
							'serviceAdd': path('devture_nagios.service.add', {'commandId': '__COMMAND_ID__', 'hostId': '__HOST_ID__'}),
						},
					} %}
					{{ reactjs_render_component('HostServicesApp', reactProps) }}
				</div>
			</div>

			<div class="row mb-3">
				<label class="col-lg-2 col-form-label"><i class="fa-solid fa-book"></i> Logs</label>
				<div class="col-lg-10">
					{% if logs|length == 0 %}
						No recent log entries related to this host.
					{% else %}
						{% include '@DevtureNagios/log/list.html.twig' with {'items': logs} only %}
					{% endif %}
				</div>
			</div>
		</fieldset>
	</div>
{% endblock %}
