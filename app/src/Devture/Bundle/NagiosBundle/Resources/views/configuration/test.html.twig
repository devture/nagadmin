{% extends '@DevtureNagios/nagios_layout.html.twig' %}

{% block title %}Configuration / {{ parent() }}{% endblock %}

{% block devture_nagios_content %}
	<div>
		<fieldset>
			<div class="row mb-3">
				<label class="col-lg-2 col-form-label">Check Status</label>
				<div class="col-lg-10">
					<div class="alert alert-{{ isValid ? 'success' : 'danger' }}">
						{% if isValid %}
							<i class="fa-solid fa-thumbs-up"></i>
							The configuration was checked and seems safe to deploy.
						{% else %}
							<i class="fa-solid fa-thumbs-down"></i>
							The configuration was checked and seems broken.
						{% endif %}
					</div>
					{% if isValid %}
						<form name="deploy" method="post" action="{{ path('devture_nagios.configuration.deploy') }}"
							id="js-deployment-form"
							class="text-center">
							<input type="hidden" name="token" value="{{ csrf_token('deploy') }}" />
							Changes are automatically deployed. You don't have to, but you can also
							<button type="submit" class="btn btn-link btn-lg" id="js-deployment-button-submit">
								<i class="fa-solid fa-retweet"></i>
								deploy manually now
							</button>
						</form>
						<div id="js-deployment-progress" class="d-none">
							<div class="progress">
								<div class="progress-bar progress-bar-striped progress-bar-animated bg-info" style="width: 100%"></div>
							</div>
						</div>
						<div id="js-deployment-result" class="top-spaced-minor"></div>
					{% endif %}
				</div>
			</div>
			<div class="row mb-3">
				<label class="col-lg-2 col-form-label">Check Output</label>
				<div class="col-lg-10">
					<pre style="max-height: 300px; overflow-y: auto;">{{ checkOutput }}</pre>
				</div>
			</div>
			<div class="row mb-3">
				<label class="col-lg-2 col-form-label">Configuration</label>
				<div class="col-lg-10">
					{% for file in files %}
						<strong>{{ file.path }}</strong>
						<pre class="top-spaced-minor" style="max-height: 300px; overflow-y: auto;">{{ file.configuration }}</pre>
						{% if not loop.last %}<hr />{% endif %}
					{% endfor %}
				</div>
			</div>
		</fieldset>
	</div>
{% endblock %}

{% block js %}
	$('#js-deployment-form').submit(function (ev) {
		ev.preventDefault();

		$('#js-deployment-button-submit').attr('disabled', true);
		$('#js-deployment-progress').removeClass('d-none');
		$('#js-deployment-result').hide();

		$.ajax({
			"url": {{ path('devture_nagios.configuration.deploy')|json_encode|raw }},
			"data": $(this).serialize(),
			"type": "POST",
			"dataType": "html"
		}).done(function (response) {
			$('#js-deployment-result').html(response);
		}).fail(function () {
			$('#js-deployment-result').html('<div class="alert alert-danger">Deployment failed. Reload the page and try again.</div>');
		}).always(function () {
			$('#js-deployment-progress').addClass('d-none');
			$('#js-deployment-result').show();
			$('#js-deployment-button-submit').attr('disabled', false);
		});
	});
{% endblock %}
