{% extends '@DevtureNagios/nagios_layout.html.twig' %}

{% block title %}Services / {{ parent() }}{% endblock %}

{% block devture_nagios_content %}
	{% set reactProps = {
		'urls': {
			'hostsInfoAll': path('devture_nagios.api.host.info'),
			'hostInfo': path('devture_nagios.api.host.info', {'id': '__ID__'}),
			'recheckServices': path('devture_nagios.api.host.recheck_services', {'id': '__ID__', 'recheckType': '__RECHECK_TYPE__', 'token': csrf_token('nagadmin')}),
			'commandsList': path('devture_nagios.api.command.list', {'type': 'serviceCheck'}),
			'hostView': path('devture_nagios.host.view', {'id': '__ID__'}),
			'hostAdd': path('devture_nagios.host.add'),
			'serviceView': path('devture_nagios.service.view', {'id': '__ID__'}),
			'serviceAdd': path('devture_nagios.service.add', {'commandId': '__COMMAND_ID__', 'hostId': '__HOST_ID__'}),
		},
	} %}
	{{ reactjs_render_component('ServicesApp', reactProps) }}
{% endblock %}
