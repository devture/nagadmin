# Application (Symfony) configuration for Nagadmin.
#
# This is the COMMITTED template. Copy it to `app/.env` (which is gitignored) and
# adjust it per deployment — `app/.env` holds the real values, including secrets:
#
#     cp app/.env.dist app/.env
#
# Infrastructure / container configuration (timezone, published ports, Nagios UI
# credentials) lives in the separate repository-root `.env` (see `.env.dist`).
#
# Real environment variables always win over what is defined in these files.

###> symfony/framework-bundle ###
APP_ENV=dev
# Used to sign CSRF tokens, cookies, etc. The value below is a development
# default; set a unique, secret value in each deployment's `app/.env`.
APP_SECRET=aecc3a158d412cab5e27c272f61e6092
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> nagadmin ###
# MongoDB connection (same defaults as the legacy config.json/parameters.json).
MONGODB_URI=mongodb://mongodb
MONGODB_DB=nagadmin

# Where the kernel keeps its mutable runtime state (cache/build/log). When empty,
# Symfony's defaults under app/var are used (fine for local CLI runs). In the
# container it is pointed at a uid-100:101-owned directory in the repo var/ tree.
NAGADMIN_RUNTIME_DIR=

# Shared secret embedded into the generated Nagios configuration ($USER2$) and
# used to authenticate the notification API. The value below is a development
# default; set a unique, secret value in each deployment's `app/.env`.
NAGADMIN_NOTIFICATION_API_SECRET=local-dev-api-secret

# From-address used for notification e-mails sent via the notification API /
# console command. Override per deployment.
NAGADMIN_NOTIFICATION_SENDER_EMAIL=nagios@localhost

# SMS notifications via Vonage (https://www.vonage.com): API credentials (secrets)
# and the sender shown to recipients (alphanumeric name or phone number).
NAGADMIN_VONAGE_API_KEY=
NAGADMIN_VONAGE_API_SECRET=
NAGADMIN_SMS_SENDER_ID=nagios

# Don't actually send SMS (there is no dev SMS catcher like mailcrab). Defaults to
# true so dev never sends real texts; set to false in production.
NAGADMIN_SMS_SUPPRESS_SENDING=true

# Display name for this deployment (shown in the navbar/title).
NAGADMIN_PROJECT_NAME=nagadmin

# URL of the external Nagios web UI (linked from the navbar). Deployment-specific;
# override in production. This default matches the local container's published port.
NAGADMIN_NAGIOS_URL=http://nagadmin.127.0.0.1.nip.io:20188
###< nagadmin ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/mailer ###
# Development default points at the `mailcrab` mail-catcher (compose.dev.yml),
# so the development environment never sends real mail — inspect captured
# messages in its web UI at http://127.0.0.1:20825.
#
# In production, point this at the bundled exim-relay `mailer` container
# (compose.prod.yml), which relays onward (smarthost) and queues on failure:
#   MAILER_DSN=smtp://mailer:8025
MAILER_DSN=smtp://mailcrab:1025
###< symfony/mailer ###
