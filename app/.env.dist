# Application (Symfony) config. Committed template — copy to the gitignored
# `app/.env` and fill in the real per-deployment values (incl. secrets):
#
#     cp app/.env.dist app/.env
#
# Container/infrastructure config (timezone, ports, Nagios UI login) lives in the
# repository-root `.env` instead. Real environment variables override these.

###> symfony/framework-bundle ###
APP_ENV=dev
# Dev default; set a unique secret per deployment in app/.env.
APP_SECRET=aecc3a158d412cab5e27c272f61e6092
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> nagadmin ###
MONGODB_URI=mongodb://mongodb
MONGODB_DB=nagadmin

# Kernel runtime state (cache/build/log). Empty = Symfony defaults under app/var;
# the container points it at a uid-100:101-owned dir in var/.
NAGADMIN_RUNTIME_DIR=

# Embedded in the generated Nagios config ($USER2$) and used to authenticate the
# notification API. Dev default; set a unique secret per deployment in app/.env.
NAGADMIN_NOTIFICATION_API_SECRET=local-dev-api-secret

# From-address for notification e-mails. Override per deployment.
NAGADMIN_NOTIFICATION_SENDER_EMAIL=nagios@localhost

# SMS notifications via Vonage (https://www.vonage.com): API credentials (secrets)
# and the sender shown to recipients (alphanumeric name or phone number).
NAGADMIN_VONAGE_API_KEY=
NAGADMIN_VONAGE_API_SECRET=
NAGADMIN_SMS_SENDER_ID=nagios

# Don't actually send SMS (no dev SMS catcher like mailcrab). Default true so dev
# never sends real texts; set false in production.
NAGADMIN_SMS_SUPPRESS_SENDING=true

# Display name shown in the navbar/title.
NAGADMIN_PROJECT_NAME=nagadmin

# URL of the external Nagios web UI (linked from the navbar). Override per
# deployment; this default matches the local published port.
NAGADMIN_NAGIOS_URL=http://nagadmin.127.0.0.1.nip.io:20188
###< nagadmin ###

###> symfony/routing ###
# Used to generate URLs in non-HTTP contexts (e.g. CLI commands).
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/mailer ###
# Dev points at the mailcrab catcher (compose.dev.yml) — view captured mail at
# http://127.0.0.1:20825. In production use the exim-relay `mailer`
# (compose.prod.yml): MAILER_DSN=smtp://mailer:8025
MAILER_DSN=smtp://mailcrab:1025
###< symfony/mailer ###
